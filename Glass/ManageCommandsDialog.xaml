<Window x:Class="Glass.ManageCommandsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Manage Commands"
        Height="500" Width="700"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: command list -->
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1">
                <ListView x:Name="CommandListView"
                          SelectionChanged="CommandListView_SelectionChanged"
                          KeyDown="CommandListView_KeyDown"
                          MouseDown="CommandListView_MouseDown"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Button x:Name="NewRenameButton" Content="New" Width="70" Margin="0,0,8,0"
                          Click="NewRename_Click" IsEnabled="False"/>
                <Button x:Name="DeleteCommandButton" Content="Delete" Width="70" IsEnabled="False" Click="DeleteCommand_Click"/>
            </StackPanel>
        </Grid>

        <!-- Right: command editor -->
        <Grid Grid.Row="0" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Name -->
            <DockPanel Grid.Row="0">
                <TextBlock DockPanel.Dock="Left" Text="Command:" VerticalAlignment="Center" Width="70" Margin="0,0,8,0"/>
                <TextBox x:Name="CommandNameTextBox"
                     TextChanged="CommandNameTextBox_TextChanged"
                     LostFocus="CommandNameTextBox_LostFocus"
                     KeyDown="CommandNameTextBox_KeyDown"/>
            </DockPanel>

            <!-- Step list -->
            <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1">
                <ListView x:Name="StepListView"
                      SelectionChanged="StepListView_SelectionChanged"
                      KeyDown="StepListView_KeyDown"
                      MouseDown="StepListView_MouseDown"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayText}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- Step reorder buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal">
                <Button Content="↑" Width="40" Margin="0,0,8,0" Click="MoveStepUp_Click"/>
                <Button Content="↓" Width="40" Click="MoveStepDown_Click"/>
            </StackPanel>

            <!-- Step editor -->
            <DockPanel Grid.Row="6">
                <TextBlock DockPanel.Dock="Left" Text="Type:" VerticalAlignment="Center" Width="70" Margin="0,0,8,0"/>
                <ComboBox x:Name="StepTypeComboBox" SelectedIndex="0">
                    <ComboBoxItem Content="text"/>
                    <ComboBoxItem Content="key"/>
                </ComboBox>
            </DockPanel>

            <DockPanel Grid.Row="8">
                <TextBlock DockPanel.Dock="Left" Text="Value:" VerticalAlignment="Center" Width="70" Margin="0,0,8,0"/>
                <TextBox x:Name="StepValueTextBox"/>
            </DockPanel>

            <DockPanel Grid.Row="10">
                <TextBlock DockPanel.Dock="Left" Text="Delay ms:" VerticalAlignment="Center" Width="70" Margin="0,0,8,0"/>
                <TextBox x:Name="StepDelayTextBox"/>
            </DockPanel>

            <!-- Step New/Delete -->
            <StackPanel Grid.Row="12" Orientation="Horizontal">
                <Button x:Name="NewUpdateStepButton" Content="New" Width="70" Margin="0,0,8,0" Click="NewUpdateStep_Click"/>
                <Button Content="Delete" Width="70" Click="DeleteStep_Click"/>
            </StackPanel>
        </Grid>

        <!-- Close button -->
        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                Content="Close" Width="70" HorizontalAlignment="Right"
                Click="Close_Click"/>
    </Grid>
</Window>