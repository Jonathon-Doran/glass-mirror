<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Glass.Controls">

    <Style TargetType="{x:Type controls:KeyDisplayControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:KeyDisplayControl}">
                    <Border x:Name="PART_Border"
                        Background="#1A2A2A"
                        BorderBrush="#2AFFD7"
                        BorderThickness="1"
                        CornerRadius="3"
                        Width="70"
                        Height="24">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="InteractionStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="Selected">
                                    <Storyboard>
                                        <ColorAnimation
                                        Storyboard.TargetName="PART_Border"
                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                        To="#FFD700"
                                        Duration="0:0:0.1"/>
                                        <ColorAnimation
                                        Storyboard.TargetName="PART_Text"
                                        Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                        To="#FFD700"
                                        Duration="0:0:0.1"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ColorAnimation
                                        Storyboard.TargetName="PART_Border"
                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                        To="#FF4500"
                                        Duration="0:0:0.05"/>
                                        <ColorAnimation
                                        Storyboard.TargetName="PART_Text"
                                        Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                        To="#FF4500"
                                        Duration="0:0:0.05"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <TextBlock x:Name="PART_Text"
                               Text="{TemplateBinding KeyName}"
                               Foreground="#2AFFD7"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowLabel" Value="True">
                            <Setter TargetName="PART_Text" Property="Text" Value="{Binding Label, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="{x:Type controls:KeyboardLayoutControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:KeyboardLayoutControl}">
                    <Border Background="#1A2A2A" Padding="5">
                        <StackPanel>
                            <!-- Page name header -->
                            <TextBlock x:Name="PART_PageName"
                                       Text="{TemplateBinding PageName}"
                                       Foreground="#2AFFD7"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,5"/>

                            <Separator x:Name="PART_PageSeparator" Background="#2AFFD7" Margin="0,0,0,5" Opacity="0.3"/>
                            <!-- G15 -->
                            <Grid x:Name="PART_G15Grid" Visibility="Collapsed"
                              HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <controls:KeyDisplayControl Grid.Row="0" Grid.Column="0" KeyName="G1"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="0" Grid.Column="1" KeyName="G2"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="0" Grid.Column="2" KeyName="G3"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="1" Grid.Column="0" KeyName="G4"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="1" Grid.Column="1" KeyName="G5"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="1" Grid.Column="2" KeyName="G6"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="3" Grid.Column="0" KeyName="G7"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="3" Grid.Column="1" KeyName="G8"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="3" Grid.Column="2" KeyName="G9"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="4" Grid.Column="0" KeyName="G10" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="4" Grid.Column="1" KeyName="G11" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="4" Grid.Column="2" KeyName="G12" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="6" Grid.Column="0" KeyName="G13" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="6" Grid.Column="1" KeyName="G14" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="6" Grid.Column="2" KeyName="G15" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="7" Grid.Column="0" KeyName="G16" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="7" Grid.Column="1" KeyName="G17" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="7" Grid.Column="2" KeyName="G18" Margin="1"/>
                            </Grid>
                            <!-- G13 -->
                            <Grid x:Name="PART_G13Grid" Visibility="Collapsed"
                                    HorizontalAlignment="Left" VerticalAlignment="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <controls:KeyDisplayControl Grid.Row="0" Grid.Column="0" KeyName="G1"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="0" Grid.Column="1" KeyName="G2"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="0" Grid.Column="2" KeyName="G3"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="0" Grid.Column="3" KeyName="G4"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="0" Grid.Column="4" KeyName="G5"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="0" Grid.Column="5" KeyName="G6"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="0" Grid.Column="6" KeyName="G7"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="1" Grid.Column="0" KeyName="G8"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="1" Grid.Column="1" KeyName="G9"  Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="1" Grid.Column="2" KeyName="G10" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="1" Grid.Column="3" KeyName="G11" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="1" Grid.Column="4" KeyName="G12" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="1" Grid.Column="5" KeyName="G13" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="1" Grid.Column="6" KeyName="G14" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="2" Grid.Column="1" KeyName="G15" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="2" Grid.Column="2" KeyName="G16" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="2" Grid.Column="3" KeyName="G17" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="2" Grid.Column="4" KeyName="G18" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="2" Grid.Column="5" KeyName="G19" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="3" Grid.Column="2" KeyName="G20" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="3" Grid.Column="3" KeyName="G21" Margin="1"/>
                                <controls:KeyDisplayControl Grid.Row="3" Grid.Column="4" KeyName="G22" Margin="1"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="PageName" Value="">
                            <Setter TargetName="PART_PageName" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="PART_PageSeparator" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>