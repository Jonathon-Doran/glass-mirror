
<Window x:Class="Glass.ProfileDialog"
        xmlns:local="clr-namespace:Glass.Core"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Profile"
        Height="800" Width="800"
        MinHeight="600" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
        <Window.Resources>
            <local:BoolToBrushConverter x:Key="BoolToBrushConverter" 
                                     TrueBrush="DodgerBlue" 
                                     FalseBrush="Gray"/>
        </Window.Resources>

    <DockPanel Margin="12">

        <!-- Profile Name -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Profile Name:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="ProfileName" Width="300"/>
        </StackPanel>

        <!-- OK / Cancel -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="SaveButton" Content="Save" Width="80" Margin="0,0,8,0" 
                IsEnabled="False" Click="Save_Click"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>

        <!-- Tabs -->
        <TabControl SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="Character Selection">
                <ListView x:Name="CharactersListView" Margin="4">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Select" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding IsEnabled}"
                                              Click="CharacterCheckBox_Click"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Character.Name}" Width="150"/>
                            <GridViewColumn Header="Class" DisplayMemberBinding="{Binding Character.Class}" Width="100"/>
                            <GridViewColumn Header="Account ID" DisplayMemberBinding="{Binding Character.AccountId}" Width="100"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
            <TabItem Header="Slot Assignment" x:Name="SlotAssignmentTab">
                <ListView x:Name="CharacterSlotsListView" Margin="4"
                          PreviewMouseLeftButtonDown="CharacterSlotsListView_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="CharacterSlotsListView_PreviewMouseMove"
                          AllowDrop="True"
                          DragOver="CharacterSlotsListView_DragOver"
                          Drop="CharacterSlotsListView_Drop">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header=" " Width="24">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="pack://application:,,,/Resources/drag_handle.png" 
                                   Width="16" Height="16"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Slot" Width="50" 
                                DisplayMemberBinding="{Binding SlotNumber}"/>
                            <GridViewColumn Header="Name" Width="150" 
                                DisplayMemberBinding="{Binding Character.Name}"/>
                            <GridViewColumn Header="Class" Width="100" 
                                DisplayMemberBinding="{Binding Character.Class}"/>
                            <GridViewColumn Header="Account" Width="100" 
                                DisplayMemberBinding="{Binding Character.AccountId}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
            <TabItem x:Name="WindowLayoutTab" Header="Window Layout">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                        <TextBlock Text="Layout Name:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="LayoutNameTextBox" Width="150"/>
                    </StackPanel>
                    
                    <!-- Monitor Count -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Number of Monitors:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="MonitorCountComboBox"
                      Width="80"
                      SelectionChanged="MonitorCountChanged">
                            <ComboBoxItem Content="1"/>
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="4"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Monitor Configuration -->
                    <ItemsControl x:Name="MonitorConfigItemsControl" ItemsSource="{Binding Monitors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{Binding IsSelectedForConfiguration, Converter={StaticResource BoolToBrushConverter}}"
                            BorderThickness="2" Margin="4">
                                    <StackPanel Margin="8">
                                        <Grid>
                                            <Rectangle x:Name="MonitorRectangle"
                                           Width="96" Height="54"
                                           Stroke="Black" Fill="LightGray"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           MouseLeftButtonDown="MonitorRectangle_MouseLeftButtonDown"
                                           Panel.ZIndex="0"/>
                                            <Canvas x:Name="OverlayCanvas"
                                                Width="{Binding OverlayCanvasWidth}"
                                                Height="{Binding OverlayCanvasHeight}"
                                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                                Background="Transparent"
                                                IsHitTestVisible="False"
                                                Panel.ZIndex="1"/>
                                        </Grid>
                                        <TextBlock Text="{Binding MonitorNumber}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        <ComboBox x:Name="comboBoxResolution" Width="120" Margin="0,4,0,0"
                                      SelectedValuePath="Content"
                                      SelectedValue="{Binding SelectedResolution}"
                                      SelectionChanged="MonitorSettingsChanged">
                                            <ComboBoxItem Content="1920x1080"/>
                                            <ComboBoxItem Content="2560x1440"/>
                                            <ComboBoxItem Content="3840x2160"/>
                                        </ComboBox>
                                        <ComboBox x:Name="comboBoxOrientation" Width="120" Margin="0,4,0,0"
                                      SelectedValuePath="Content"
                                      SelectedValue="{Binding Orientation}"
                                      SelectionChanged="MonitorSettingsChanged">
                                            <ComboBoxItem Content="Landscape"/>
                                            <ComboBoxItem Content="Portrait"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Monitor Device Name -->
                    <ComboBox x:Name="MonitorNameComboBox"
                  ItemsSource="{Binding MonitorComboBoxItems}"
                  Width="200" HorizontalAlignment="Left" Margin="0,8,0,0"/>

                    <!-- Layout Strategy -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Layout Strategy:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="LayoutStrategyComboBox" Width="200"
                      IsEnabled="False" SelectedIndex="0"
                      SelectionChanged="LayoutStrategyChanged">
                            <ComboBoxItem Content="Fixed Window Size" ToolTip="Each character window has a fixed size."/>
                            <ComboBoxItem Content="Subset and Swap"   ToolTip="Display a subset of windows and swap between them."/>
                            <ComboBoxItem Content="Summary Windows"   ToolTip="Display summary windows and focus full windows as needed."/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Preferred Window Size -->
                    <StackPanel x:Name="WindowSizeInputs" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                        <TextBlock Text="Preferred Size:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="PreferredSizeTextBlock" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="PreferredWidthSlider"
                    Minimum="100" Maximum="3840" Width="200"
                    SmallChange="10" LargeChange="100"
                    IsSnapToTickEnabled="True"
                    ValueChanged="PreferredWidthSlider_ValueChanged"/>
                    </StackPanel>

                    <!-- Grid Size -->
                    <StackPanel x:Name="GridSizeInputs" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                        <TextBlock Text="Grid Size:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="GridSizeTextBlock" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="Total Slots:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TotalSlotsTextBlock" VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </TabItem>
            <TabItem Header="Keyboard Layout">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left side -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="150"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Page list -->
                        <GroupBox Grid.Row="0" Header="Pages">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,4,0,0">
                                    <Button x:Name="NewPageButton" Content="New" Width="60" Margin="0,0,4,0" Click="NewPage_Click"/>
                                    <Button x:Name="RenamePageButton" Content="Rename" Width="60" Margin="0,0,4,0" Click="RenamePage_Click"/>
                                    <Button x:Name="DeletePageButton" Content="Delete" Width="60" Click="DeletePage_Click"/>
                                </StackPanel>
                                <ListView x:Name="PageListView" SelectionChanged="PageListView_SelectionChanged">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStartPage}" Value="True">
                                                    <Setter Property="Background" Value="LightGreen"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="In Use" Width="55">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding InProfile, Mode=TwoWay}"
                                                      Click="PageInProfile_Click"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Start" Width="50">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsStartPage, Mode=TwoWay}"
                                                      Click="PageIsStart_Click"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="120"/>
                                            <GridViewColumn Header="Device" DisplayMemberBinding="{Binding Device}" Width="100"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </DockPanel>
                        </GroupBox>

                        <!-- Key layout grid -->
                        <GroupBox Grid.Row="2" Header="Key Layout">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <!-- G13 -->
                                    <Grid x:Name="G13Grid" HorizontalAlignment="Center" VerticalAlignment="Top" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Row="0" Grid.Column="0" Content="G1"  Width="50" Margin="3" Tag="G1"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="0" Grid.Column="1" Content="G2"  Width="50" Margin="3" Tag="G2"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="0" Grid.Column="2" Content="G3"  Width="50" Margin="3" Tag="G3"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="0" Grid.Column="3" Content="G4"  Width="50" Margin="3" Tag="G4"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="0" Grid.Column="4" Content="G5"  Width="50" Margin="3" Tag="G5"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="0" Grid.Column="5" Content="G6"  Width="50" Margin="3" Tag="G6"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="0" Grid.Column="6" Content="G7"  Width="50" Margin="3" Tag="G7"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="0" Content="G8"  Width="50" Margin="3" Tag="G8"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="1" Content="G9"  Width="50" Margin="3" Tag="G9"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="2" Content="G10" Width="50" Margin="3" Tag="G10" Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="3" Content="G11" Width="50" Margin="3" Tag="G11" Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="4" Content="G12" Width="50" Margin="3" Tag="G12" Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="5" Content="G13" Width="50" Margin="3" Tag="G13" Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="6" Content="G14" Width="50" Margin="3" Tag="G14" Click="KeyButton_Click"/>
                                        <Button Grid.Row="2" Grid.Column="1" Content="G15" Width="50" Margin="3" Tag="G15" Click="KeyButton_Click"/>
                                        <Button Grid.Row="2" Grid.Column="2" Content="G16" Width="50" Margin="3" Tag="G16" Click="KeyButton_Click"/>
                                        <Button Grid.Row="2" Grid.Column="3" Content="G17" Width="50" Margin="3" Tag="G17" Click="KeyButton_Click"/>
                                        <Button Grid.Row="2" Grid.Column="4" Content="G18" Width="50" Margin="3" Tag="G18" Click="KeyButton_Click"/>
                                        <Button Grid.Row="2" Grid.Column="5" Content="G19" Width="50" Margin="3" Tag="G19" Click="KeyButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="2" Content="G20" Width="50" Margin="3" Tag="G20" Click="KeyButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="3" Content="G21" Width="50" Margin="3" Tag="G21" Click="KeyButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="4" Content="G22" Width="50" Margin="3" Tag="G22" Click="KeyButton_Click"/>
                                    </Grid>

                                    <!-- G15 -->
                                    <Grid x:Name="G15Grid" HorizontalAlignment="Center" VerticalAlignment="Top" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Row="0" Grid.Column="0" Content="G1"  Margin="3" Tag="G1"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="0" Grid.Column="1" Content="G2"  Margin="3" Tag="G2"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="0" Grid.Column="2" Content="G3"  Margin="3" Tag="G3"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="0" Content="G4"  Margin="3" Tag="G4"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="1" Content="G5"  Margin="3" Tag="G5"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="2" Content="G6"  Margin="3" Tag="G6"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="0" Content="G7"  Margin="3" Tag="G7"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="1" Content="G8"  Margin="3" Tag="G8"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="2" Content="G9"  Margin="3" Tag="G9"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="4" Grid.Column="0" Content="G10" Margin="3" Tag="G10" Click="KeyButton_Click"/>
                                        <Button Grid.Row="4" Grid.Column="1" Content="G11" Margin="3" Tag="G11" Click="KeyButton_Click"/>
                                        <Button Grid.Row="4" Grid.Column="2" Content="G12" Margin="3" Tag="G12" Click="KeyButton_Click"/>
                                        <Button Grid.Row="6" Grid.Column="0" Content="G13" Margin="3" Tag="G13" Click="KeyButton_Click"/>
                                        <Button Grid.Row="6" Grid.Column="1" Content="G14" Margin="3" Tag="G14" Click="KeyButton_Click"/>
                                        <Button Grid.Row="6" Grid.Column="2" Content="G15" Margin="3" Tag="G15" Click="KeyButton_Click"/>
                                        <Button Grid.Row="7" Grid.Column="0" Content="G16" Margin="3" Tag="G16" Click="KeyButton_Click"/>
                                        <Button Grid.Row="7" Grid.Column="1" Content="G17" Margin="3" Tag="G17" Click="KeyButton_Click"/>
                                        <Button Grid.Row="7" Grid.Column="2" Content="G18" Margin="3" Tag="G18" Click="KeyButton_Click"/>
                                    </Grid>

                                    <!-- Dominator X36 -->
                                    <Grid x:Name="DominatorX36Grid" HorizontalAlignment="Center" VerticalAlignment="Top" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Row="0" Grid.Column="0" Content="X-1"  Margin="3" Tag="X-1"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="0" Grid.Column="1" Content="X-2"  Margin="3" Tag="X-2"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="0" Grid.Column="2" Content="X-3"  Margin="3" Tag="X-3"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="0" Content="X-4"  Margin="3" Tag="X-4"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="1" Content="X-5"  Margin="3" Tag="X-5"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="2" Content="X-6"  Margin="3" Tag="X-6"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="0" Content="X-7"  Margin="3" Tag="X-7"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="1" Content="X-8"  Margin="3" Tag="X-8"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="2" Content="X-9"  Margin="3" Tag="X-9"  Click="KeyButton_Click"/>
                                        <Button Grid.Row="4" Grid.Column="0" Content="X-10" Margin="3" Tag="X-10" Click="KeyButton_Click"/>
                                        <Button Grid.Row="4" Grid.Column="1" Content="X-11" Margin="3" Tag="X-11" Click="KeyButton_Click"/>
                                        <Button Grid.Row="4" Grid.Column="2" Content="X-12" Margin="3" Tag="X-12" Click="KeyButton_Click"/>
                                        <Button Grid.Row="6" Grid.Column="0" Content="X-13" Margin="3" Tag="X-13" Click="KeyButton_Click"/>
                                        <Button Grid.Row="6" Grid.Column="1" Content="X-14" Margin="3" Tag="X-14" Click="KeyButton_Click"/>
                                        <Button Grid.Row="6" Grid.Column="2" Content="X-15" Margin="3" Tag="X-15" Click="KeyButton_Click"/>
                                        <Button Grid.Row="7" Grid.Column="0" Content="X-16" Margin="3" Tag="X-16" Click="KeyButton_Click"/>
                                        <Button Grid.Row="7" Grid.Column="1" Content="X-17" Margin="3" Tag="X-17" Click="KeyButton_Click"/>
                                        <Button Grid.Row="7" Grid.Column="2" Content="X-18" Margin="3" Tag="X-18" Click="KeyButton_Click"/>
                                        <Button Grid.Row="0" Grid.Column="4" Content="X-19" Margin="3" Tag="X-19" Click="KeyButton_Click"/>
                                        <Button Grid.Row="0" Grid.Column="5" Content="X-20" Margin="3" Tag="X-20" Click="KeyButton_Click"/>
                                        <Button Grid.Row="0" Grid.Column="6" Content="X-21" Margin="3" Tag="X-21" Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="4" Content="X-22" Margin="3" Tag="X-22" Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="5" Content="X-23" Margin="3" Tag="X-23" Click="KeyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="6" Content="X-24" Margin="3" Tag="X-24" Click="KeyButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="4" Content="X-25" Margin="3" Tag="X-25" Click="KeyButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="5" Content="X-26" Margin="3" Tag="X-26" Click="KeyButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="6" Content="X-27" Margin="3" Tag="X-27" Click="KeyButton_Click"/>
                                        <Button Grid.Row="4" Grid.Column="4" Content="X-28" Margin="3" Tag="X-28" Click="KeyButton_Click"/>
                                        <Button Grid.Row="4" Grid.Column="5" Content="X-29" Margin="3" Tag="X-29" Click="KeyButton_Click"/>
                                        <Button Grid.Row="4" Grid.Column="6" Content="X-30" Margin="3" Tag="X-30" Click="KeyButton_Click"/>
                                        <Button Grid.Row="6" Grid.Column="4" Content="X-31" Margin="3" Tag="X-31" Click="KeyButton_Click"/>
                                        <Button Grid.Row="6" Grid.Column="5" Content="X-32" Margin="3" Tag="X-32" Click="KeyButton_Click"/>
                                        <Button Grid.Row="6" Grid.Column="6" Content="X-33" Margin="3" Tag="X-33" Click="KeyButton_Click"/>
                                        <Button Grid.Row="7" Grid.Column="4" Content="X-34" Margin="3" Tag="X-34" Click="KeyButton_Click"/>
                                        <Button Grid.Row="7" Grid.Column="5" Content="X-35" Margin="3" Tag="X-35" Click="KeyButton_Click"/>
                                        <Button Grid.Row="7" Grid.Column="6" Content="X-36" Margin="3" Tag="X-36" Click="KeyButton_Click"/>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </GroupBox>

                        <!-- Binding editor -->
                        <GroupBox Grid.Row="4" Header="Binding">
                            <Grid Margin="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Key:" VerticalAlignment="Center" Margin="0,4,8,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SelectedKeyTextBlock" VerticalAlignment="Center" Margin="0,4,0,4"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Command Type:" VerticalAlignment="Center" Margin="0,4,8,4"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="CommandTypeComboBox" Margin="0,4,0,4">
                                    <ComboBoxItem Content="key"/>
                                    <ComboBoxItem Content="text"/>
                                </ComboBox>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Action:" VerticalAlignment="Center" Margin="0,4,8,4"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="ActionTextBox" Margin="0,4,0,4"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Target Group:" VerticalAlignment="Center" Margin="0,4,8,4"/>
                                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="TargetGroupComboBox" Margin="0,4,0,4"/>

                                <CheckBox Grid.Row="4" Grid.Column="1" x:Name="RoundRobinCheckBox" Content="Round Robin" Margin="0,4,0,4"/>

                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button x:Name="SaveBindingButton" Content="Save" Width="70" Margin="0,0,8,0" Click="SaveBinding_Click"/>
                                    <Button x:Name="ClearBindingButton" Content="Clear" Width="70" Click="ClearBinding_Click"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </Grid>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                    <!-- Right side — binding list -->
                    <GroupBox Grid.Column="2" Header="Bindings">
                        <ListView x:Name="BindingListView" SelectionChanged="BindingListView_SelectionChanged">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Binding" DisplayMemberBinding="{Binding DisplayText}" Width="220"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>

    </DockPanel>
