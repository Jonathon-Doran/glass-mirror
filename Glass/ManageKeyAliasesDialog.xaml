<Window x:Class="Glass.ManageKeyAliasesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Manage Key Aliases"
        Height="400" Width="500"
        MinHeight="300" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: alias list -->
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1">
                <ListView x:Name="AliasListView"
                          SelectionChanged="AliasListView_SelectionChanged"
                          KeyDown="AliasListView_KeyDown"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="4,2,4,2"/>
                            <Setter Property="MinHeight" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Button x:Name="NewRenameButton" Content="New" Width="70" Margin="0,0,8,0"
                        Click="NewRename_Click" IsEnabled="False"/>
                <Button x:Name="DeleteAliasButton" Content="Delete" Width="70" IsEnabled="False"
                        Click="DeleteAlias_Click"/>
            </StackPanel>
        </Grid>

        <!-- Right: alias editor -->
        <Grid Grid.Row="0" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <TextBlock DockPanel.Dock="Left" Text="Name:" VerticalAlignment="Center" Width="70" Margin="0,0,8,0"/>
                <TextBox x:Name="AliasNameTextBox"
                         TextChanged="AliasNameTextBox_TextChanged"
                         LostFocus="AliasNameTextBox_LostFocus"
                         KeyDown="AliasNameTextBox_KeyDown"/>
            </DockPanel>

            <DockPanel Grid.Row="2">
                <TextBlock DockPanel.Dock="Left" Text="Keystroke:" VerticalAlignment="Center" Width="70" Margin="0,0,8,0"/>
                <TextBox x:Name="AliasValueTextBox"
                         LostFocus="AliasValueTextBox_LostFocus"/>
            </DockPanel>
        </Grid>

        <!-- Close button -->
        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                Content="Close" Width="70" HorizontalAlignment="Right"
                Click="Close_Click"/>
    </Grid>
</Window>