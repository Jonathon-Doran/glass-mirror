
<Window x:Class="Glass.ProfileDialog"
        xmlns:local="clr-namespace:Glass.Core"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:controls="clr-namespace:Glass.Controls"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Profile"
        Height="800" Width="800"
        MinHeight="600" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
        <Window.Resources>
            <local:BoolToBrushConverter x:Key="BoolToBrushConverter" 
                                     TrueBrush="DodgerBlue" 
                                     FalseBrush="Gray"/>
        </Window.Resources>

    <DockPanel Margin="12">

        <!-- Profile Name -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Profile Name:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="ProfileName" Width="300"/>
        </StackPanel>

        <!-- Machine -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Machine:" VerticalAlignment="Center" Margin="0,0,8,0" Width="90"/>
            <ComboBox x:Name="MachineComboBox" Width="300"
              SelectionChanged="MachineComboBox_SelectionChanged"/>
        </StackPanel>
        
        <!-- OK / Cancel -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="SaveButton" Content="Save" Width="80" Margin="0,0,8,0" 
                IsEnabled="False" Click="Save_Click"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>

        <!-- Tabs -->
        <TabControl SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="Character Selection">
                <ListView x:Name="CharactersListView" Margin="4">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Select" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding IsEnabled}"
                                              Click="CharacterCheckBox_Click"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Character.Name}" Width="150"/>
                            <GridViewColumn Header="Class" DisplayMemberBinding="{Binding Character.Class}" Width="100"/>
                            <GridViewColumn Header="Account ID" DisplayMemberBinding="{Binding Character.AccountId}" Width="100"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
            <TabItem Header="Slot Assignment" x:Name="SlotAssignmentTab">
                <ListView x:Name="CharacterSlotsListView" Margin="4"
                          PreviewMouseLeftButtonDown="CharacterSlotsListView_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="CharacterSlotsListView_PreviewMouseMove"
                          AllowDrop="True"
                          DragOver="CharacterSlotsListView_DragOver"
                          Drop="CharacterSlotsListView_Drop">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header=" " Width="24">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="pack://application:,,,/Resources/drag_handle.png" 
                                   Width="16" Height="16"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Slot" Width="50" 
                                DisplayMemberBinding="{Binding SlotNumber}"/>
                            <GridViewColumn Header="Name" Width="150" 
                                DisplayMemberBinding="{Binding CharacterName}"/>
                            <GridViewColumn Header="Class" Width="100" 
                                DisplayMemberBinding="{Binding ClassName}"/>
                            <GridViewColumn Header="Account" Width="100" 
                                DisplayMemberBinding="{Binding AccountId}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
            <TabItem x:Name="WindowLayoutTab" Header="Window Layout">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                        <TextBlock Text="Layout Name:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="LayoutNameTextBox" Width="150"/>
                    </StackPanel>
                    
                    <!-- Monitor Count -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Number of Monitors:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="MonitorCountComboBox"
                      Width="80"
                      SelectionChanged="MonitorCountChanged">
                            <ComboBoxItem Content="1"/>
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="4"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Monitor Configuration -->
                    <ItemsControl x:Name="MonitorConfigItemsControl" ItemsSource="{Binding Monitors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{Binding IsSelectedForConfiguration, Converter={StaticResource BoolToBrushConverter}}"
                            BorderThickness="2" Margin="4">
                                    <StackPanel Margin="8">
                                        <Grid>
                                            <Rectangle x:Name="MonitorRectangle"
                                           Width="96" Height="54"
                                           Stroke="Black" Fill="LightGray"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           MouseLeftButtonDown="MonitorRectangle_MouseLeftButtonDown"
                                           Panel.ZIndex="0"/>
                                            <Canvas x:Name="OverlayCanvas"
                                                Width="{Binding OverlayCanvasWidth}"
                                                Height="{Binding OverlayCanvasHeight}"
                                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                                Background="Transparent"
                                                IsHitTestVisible="False"
                                                Panel.ZIndex="1"/>
                                        </Grid>
                                        <TextBlock Text="{Binding MonitorNumber}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        <ComboBox x:Name="comboBoxResolution" Width="120" Margin="0,4,0,0"
                                              SelectedValuePath="Content"
                                              SelectedValue="{Binding SelectedResolution}"
                                              SelectionChanged="MonitorSettingsChanged">
                                            <ComboBoxItem Content="1920x1080"/>
                                            <ComboBoxItem Content="2560x1440"/>
                                            <ComboBoxItem Content="3840x2160"/>
                                        </ComboBox>
                                        <ComboBox x:Name="comboBoxOrientation" Width="120" Margin="0,4,0,0"
                                      SelectedValuePath="Content"
                                      SelectedValue="{Binding Orientation}"
                                      SelectionChanged="MonitorSettingsChanged">
                                            <ComboBoxItem Content="Landscape"/>
                                            <ComboBoxItem Content="Portrait"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Monitor Device Name -->
                    <ComboBox x:Name="MonitorNameComboBox"
                  ItemsSource="{Binding MonitorComboBoxItems}"
                  Width="200" HorizontalAlignment="Left" Margin="0,8,0,0"/>

                    <!-- Layout Strategy -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Layout Strategy:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="LayoutStrategyComboBox" Width="200"
                      IsEnabled="False" SelectedIndex="0"
                      SelectionChanged="LayoutStrategyChanged">
                            <ComboBoxItem Content="Fixed Window Size" ToolTip="Each character window has a fixed size."/>
                            <ComboBoxItem Content="Subset and Swap"   ToolTip="Display a subset of windows and swap between them."/>
                            <ComboBoxItem Content="Summary Windows"   ToolTip="Display summary windows and focus full windows as needed."/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Preferred Window Size -->
                    <StackPanel x:Name="WindowSizeInputs" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                        <TextBlock Text="Preferred Size:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="PreferredSizeTextBlock" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="PreferredWidthSlider"
                    Minimum="100" Maximum="3840" Width="200"
                    SmallChange="10" LargeChange="100"
                    IsSnapToTickEnabled="True"
                    ValueChanged="PreferredWidthSlider_ValueChanged"/>
                    </StackPanel>

                    <!-- Grid Size -->
                    <StackPanel x:Name="GridSizeInputs" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                        <TextBlock Text="Grid Size:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="GridSizeTextBlock" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="Total Slots:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TotalSlotsTextBlock" VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </TabItem>
            <TabItem x:Name="KeyboardLayoutTab" Header="Keyboard Layout">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top bar: page selection -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="Page:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="PageComboBox" Width="400"
                                    SelectionChanged="PageComboBox_SelectionChanged"/>
                        <Button Content="Assign Pages..." Margin="8,0,0,0" 
                                     Click="AssignPages_Click"/>
                        <CheckBox x:Name="ShowLabelsCheckBox" Content="Show Labels"
                                     VerticalAlignment="Center" Margin="16,0,0,0"
                                    IsChecked="{Binding ShowLabel, ElementName=KeyLayoutControl, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- Hidden elements kept for code-behind compatibility -->
                    <StackPanel Grid.Row="0" Visibility="Collapsed">
                        <TextBlock x:Name="SelectedKeyTextBlock"/>
                        <TextBox   x:Name="ActionTextBox"/>
                        <Button    x:Name="NewPageButton"    Click="NewPage_Click"/>
                        <Button    x:Name="RenamePageButton" Click="RenamePage_Click"/>
                        <Button    x:Name="DeletePageButton" Click="DeletePage_Click"/>
                        <ListView  x:Name="PageListView" SelectionChanged="PageListView_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <TextBlock x:Name="DeviceLabel" Grid.Row="2"
                           FontWeight="Bold" HorizontalAlignment="Left"
                           Visibility="Collapsed"/>
                    
                    <!-- Middle: key grid left, binding list right -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="500"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <controls:KeyboardLayoutControl Grid.Column="0"
                                x:Name="KeyLayoutControl"
                                ShowLabel="False"
                                KeyPressed="KeyLayoutControl_KeyPressed"/>

                        <!-- Binding list -->
                        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1">
                            <ListView Grid.Column="1" x:Name="BindingListView"
                                      SelectionChanged="BindingListView_SelectionChanged"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="4,2,4,2"/>
                                        <Setter Property="MinHeight" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding CommandTargetText}"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                    </Grid>

                    <!-- Bottom: binding editor -->
                    <Grid Grid.Row="6" Margin="0,4,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="650"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Row="0" Grid.ColumnSpan="3">
                            <TextBlock DockPanel.Dock="Left" Text="Command:" VerticalAlignment="Center" Width="70"/>
                            <ComboBox DockPanel.Dock="Right" x:Name="TriggerOnComboBox" Width="140" Margin="28,0,0,0" SelectedIndex="0">
                                <ComboBoxItem Content="Press" Tag="0"/>
                                <ComboBoxItem Content="Release" Tag="1"/>
                                <ComboBoxItem Content="Both" Tag="2"/>
                            </ComboBox>
                            <ComboBox x:Name="CommandTypeComboBox" Width="500" SelectionChanged="CommandTypeComboBox_SelectionChanged"/>
                        </DockPanel>
                        <DockPanel Grid.Row="2" Grid.ColumnSpan="3">
                            <TextBlock DockPanel.Dock="Left" Text="Target:" VerticalAlignment="Center" Width="70"/>
                            <CheckBox DockPanel.Dock="Right" x:Name="RoundRobinCheckBox"
                                        Content="Round Robin" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            <ComboBox x:Name="TargetGroupComboBox" Width="500"/>
                        </DockPanel>
                        <DockPanel Grid.Row="4" Grid.ColumnSpan="3">
                            <TextBlock DockPanel.Dock="Left" Text="Label:" VerticalAlignment="Center" Width="70"/>
                            <TextBox x:Name="LabelTextBox" Width="500" HorizontalAlignment="Left"/>
                        </DockPanel>
                        <StackPanel Grid.Row="5" Grid.ColumnSpan="3" Orientation="Horizontal">
                            <Button x:Name="SaveBindingButton"  Content="Assign" Width="70" Margin="0,0,8,0"
                                       Click="SaveBinding_Click"/>
                            <Button x:Name="ClearBindingButton" Content="Clear"  Width="70"
                                        Click="ClearBinding_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem x:Name="RelayGroupsTab" Header="Relay Groups">
                <controls:RelayGroupMatrix x:Name="RelayGroupMatrixControl" Margin="8"/>
            </TabItem>
        </TabControl>

    </DockPanel>
</Window>