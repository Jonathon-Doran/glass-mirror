<Window x:Class="Glass.ManageVideoDestinationsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Manage Video Destinations"
        Height="500" Width="700"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Left Side: Destinations List -->
        <Grid Grid.Column="0" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1">
                <ListView x:Name="DestinationListView"
                          SelectionChanged="DestinationListView_SelectionChanged"
                          KeyDown="DestinationListView_KeyDown"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                            <Setter Property="Padding" Value="4,2,4,2"/>
                            <Setter Property="MinHeight" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                <Button x:Name="NewUpdateButton" Content="New" Width="80" Margin="0,0,8,0" 
                        Click="NewUpdateButton_Click" IsEnabled="False"/>
                <Button x:Name="DeleteButton" Content="Delete" Width="80" IsEnabled="False"
                        Click="DeleteButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Right Side: Edit Panel -->
        <Border Grid.Column="2" Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Padding="12">
            <StackPanel>
                <TextBlock Text="Video Destination" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>

                <TextBlock Text="Name:" Margin="0,0,0,4"/>
                <TextBox x:Name="NameTextBox" Margin="0,0,0,12" 
                         TextChanged="NameTextBox_TextChanged"/>

                <TextBlock Text="X:" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="XTextBox" Grid.Column="0" Width="60" HorizontalAlignment="Left"/>
                    <ToggleButton x:Name="PositionOverlayButton" Grid.Column="1"
                                  Width="32" Height="32" Padding="0" 
                                  HorizontalAlignment="Right"
                                  Checked="PositionOverlayButton_Checked"
                                  Unchecked="PositionOverlayButton_Unchecked">
                        <Image Source="pack://application:,,,/Resources/target.png" Width="24" Height="24"/>
                    </ToggleButton>
                </Grid>

                <TextBlock Text="Y:" Margin="0,0,0,4"/>
                <TextBox x:Name="YTextBox" Width="60" HorizontalAlignment="Left" Margin="0,0,0,12"/>

                <TextBlock Text="Width:" Margin="0,0,0,4"/>
                <TextBox x:Name="WidthTextBox" Width="60" HorizontalAlignment="Left" Margin="0,0,0,12"/>

                <TextBlock Text="Height:" Margin="0,0,0,4"/>
                <TextBox x:Name="HeightTextBox" Width="60" HorizontalAlignment="Left" Margin="0,0,0,12"/>
            </StackPanel>
        </Border>

        <!-- Cancel Button -->
        <StackPanel Grid.Column="2" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
