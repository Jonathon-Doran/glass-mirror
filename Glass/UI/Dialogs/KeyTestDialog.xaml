<Window x:Class="Glass.KeyTestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Glass.Controls"
        Title="Key Test"
        Width="200"
        Height="150"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <controls:KeyDisplayControl KeyName="MMMMMM" Margin="1"/>
            <controls:KeyDisplayControl KeyName="123456" Margin="1"/>
        </StackPanel>

    </Grid>
</Window>
