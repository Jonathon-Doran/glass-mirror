<Window x:Class="Glass.SelectProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Edit Profile"
        Height="400" Width="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel Margin="12">

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="OKButton" Content="OK" Width="80" Margin="0,0,8,0"
                    IsEnabled="False" Click="OK_Click"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>

        <ListView x:Name="ProfileList"
          SelectionChanged="ProfileList_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Profile" Width="340"
                            DisplayMemberBinding="{Binding}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
