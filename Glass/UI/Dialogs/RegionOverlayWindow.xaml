<Window x:Class="Glass.UI.Dialogs.RegionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        Width="200"
        Height="150"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid x:Name="RootGrid">
        <!-- Main border -->
        <Border x:Name="MainBorder"
                BorderThickness="1"
                Background="#33FFFFFF">
            <Grid>
                <!-- Corner handles -->
                <!-- Top-left -->
                <Canvas>
                    <Path x:Name="TopLeftHandle"
                          Stroke="White"
                          StrokeThickness="2"
                          Data="M 0,12 L 0,0 L 12,0"
                          Canvas.Left="0"
                          Canvas.Top="0"
                          MouseLeftButtonDown="TopLeftHandle_MouseLeftButtonDown"
                          Cursor="SizeNWSE"/>
                </Canvas>

                <!-- Top-right -->
                <Canvas>
                    <Path x:Name="TopRightHandle"
                          Stroke="White"
                          StrokeThickness="2"
                          Data="M -12,0 L 0,0 L 0,12"
                          Canvas.Right="0"
                          Canvas.Top="0"
                          MouseLeftButtonDown="TopRightHandle_MouseLeftButtonDown"
                          Cursor="SizeNESW"/>
                </Canvas>

                <!-- Bottom-left -->
                <Canvas>
                    <Path x:Name="BottomLeftHandle"
                          Stroke="White"
                          StrokeThickness="2"
                          Data="M 0,-12 L 0,0 L 12,0"
                          Canvas.Left="0"
                          Canvas.Bottom="0"
                          MouseLeftButtonDown="BottomLeftHandle_MouseLeftButtonDown"
                          Cursor="SizeNESW"/>
                </Canvas>

                <!-- Bottom-right -->
                <Canvas>
                    <Path x:Name="BottomRightHandle"
                          Stroke="White"
                          StrokeThickness="2"
                          Data="M -12,0 L 0,0 L 0,-12"
                          Canvas.Right="0"
                          Canvas.Bottom="0"
                          MouseLeftButtonDown="BottomRightHandle_MouseLeftButtonDown"
                          Cursor="SizeNWSE"/>
                </Canvas>
            </Grid>
        </Border>
    </Grid>
</Window>