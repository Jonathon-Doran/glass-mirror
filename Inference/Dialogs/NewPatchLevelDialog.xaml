<Window x:Class="Inference.Dialogs.NewPatchLevelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="New Patch Level" Height="230" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="Server Type" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="RadioTest" Content="Test" IsChecked="True" Margin="0,0,16,0"/>
            <RadioButton x:Name="RadioLive" Content="Live"/>
        </StackPanel>
        <TextBlock Text="Patch Date" Margin="0,0,0,4"/>
        <DatePicker x:Name="PatchDatePicker" SelectedDate="{x:Static sys:DateTime.Today}"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    Margin="0,0,0,16"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Click="Button_OK_Click" Padding="16,4" Margin="0,0,8,0"/>
            <Button Content="Cancel" Click="Button_Cancel_Click" Padding="16,4"/>
        </StackPanel>
    </StackPanel>
</Window>
